{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "strict": false,
    "strictNullChecks": false,
    "strictFunctionTypes": false,
    "strictBindCallApply": false,
    "strictPropertyInitialization": false,
    "noImplicitAny": false,
    "noImplicitThis": false
  },
  "exclude": [
    "node_modules",
    "dist",
    "build",
    "*.config.js"
  ]
}
